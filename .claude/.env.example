# ============================================================================
# .claude/.env  —  config for the edit-recipe skill (local, gitignored).
#
# Copy to .claude/.env and fill in your values. Never commit the real .env.
#
# Generate a fresh token (run on either Mac or VPS):
#   openssl rand -hex 32
#
# The same token must be set on the VPS as the RECIPE_API_TOKEN env var
# (typically in /opt/recipe-db/.env, which docker-compose loads automatically).
# ============================================================================

# Public URL of the Flask app on the VPS, no trailing slash.
# Examples:
#   RECIPE_API_URL=https://recipes.example.com
#   RECIPE_API_URL=http://187.77.67.116
RECIPE_API_URL=

# Bearer token used by the edit-recipe skill to authenticate against
# /api/recipe/* endpoints. Must match the value on the VPS.
RECIPE_API_TOKEN=
